{
  "name": "reimbursd",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first expense and receipt tracking for mobile and web",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react-native-svg": "15.15.4"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace @reimbursd/api",
    "dev:mobile": "npm run start --workspace @reimbursd/mobile",
    "dev:worker": "npm run dev --workspace @reimbursd/worker",
    "doctor": "expo-doctor apps/mobile",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:ui": "npm run test:ui --workspace @reimbursd/mobile",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=high",
    "licenses": "license-checker-rseidelsohn --excludePrivatePackages --summary --onlyAllow \"0BSD;Apache-2.0;BlueOak-1.0.0;BSD-2-Clause;BSD-3-Clause;CC-BY-3.0;CC-BY-4.0;CC0-1.0;ISC;MIT;MIT-0;MPL-2.0;Python-2.0;Unlicense;Unicode-3.0\"",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:ui && npm run licenses && npm run audit && npm run doctor && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-expo": "~57.0.0",
    "expo-doctor": "1.20.0",
    "license-checker-rseidelsohn": "4.4.2",
    "prettier": "^3.8.3",
    "vitest": "^4.0.0"
  }
}
