{
  "name": "@reimbursd/mobile",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "android": "cross-env EXPO_NO_TELEMETRY=1 expo start --android",
    "android:native": "cross-env EXPO_NO_TELEMETRY=1 expo run:android",
    "ios": "cross-env EXPO_NO_TELEMETRY=1 expo start --ios",
    "ios:native": "cross-env EXPO_NO_TELEMETRY=1 expo run:ios",
    "web": "cross-env EXPO_NO_TELEMETRY=1 expo start --web",
    "build": "cross-env EXPO_NO_TELEMETRY=1 expo export --platform web --output-dir dist --clear",
    "test:ui": "jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reimbursd/attachments": "*",
    "@reimbursd/database": "*",
    "@reimbursd/domain": "*",
    "@reimbursd/extraction": "*",
    "@reimbursd/ocr": "*",
    "expo": "~57.0.7",
    "expo-crypto": "~57.0.1",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-image-manipulator": "~57.0.5",
    "expo-image-picker": "~57.0.5",
    "expo-sharing": "~57.0.6",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "typescript": "~6.0.3"
  },
  "jest": {
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*-test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|lucide-react-native|react-native-svg)"
    ]
  }
}
