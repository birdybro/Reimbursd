# The local mobile application requires no environment variables or external services.

# Milestone 6 API development only. Generate a random secret of at least 32 characters.
NODE_ENV=development
REIMBURSD_API_HOST=127.0.0.1
REIMBURSD_API_PORT=3000
REIMBURSD_API_JWT_SECRET=
REIMBURSD_DEV_AUTH_ENABLED=true

# Optional durable API storage. Keep the password and URL values out of Git.
REIMBURSD_POSTGRES_DATABASE=reimbursd
REIMBURSD_POSTGRES_USER=reimbursd
REIMBURSD_POSTGRES_PASSWORD=
REIMBURSD_POSTGRES_PORT=5432
REIMBURSD_DATABASE_URL=

# Optional private S3-compatible storage. For this local-only Compose stack, set both object
# credentials to the same uncommitted values as the MinIO root credentials below.
REIMBURSD_OBJECT_ENDPOINT=http://127.0.0.1:9000
REIMBURSD_OBJECT_REGION=us-east-1
REIMBURSD_OBJECT_BUCKET=reimbursd-receipts
REIMBURSD_OBJECT_ACCESS_KEY_ID=
REIMBURSD_OBJECT_SECRET_ACCESS_KEY=
REIMBURSD_OBJECT_FORCE_PATH_STYLE=true

# Local MinIO only. The administration console is not published.
REIMBURSD_MINIO_ROOT_USER=
REIMBURSD_MINIO_ROOT_PASSWORD=
REIMBURSD_MINIO_PORT=9000
